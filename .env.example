# Copy to .env and fill in real values. Never commit a real .env file.

# Set to true to run the whole platform on in-memory stores -- no Postgres or
# Redis needed at all (DATABASE_URL/REDIS_URL become optional). Every visitor
# is auto-provisioned with the starting balance and all 9 games + the
# provably-fair seed flow work normally. All state resets on restart and is
# not shared across serverless instances; for trying the games out only.
# DEMO_MODE=true

DATABASE_URL=postgresql://cplatform:cplatform@localhost:5432/cplatform
NODE_ENV=development
PORT=4000
REDIS_URL=redis://localhost:6379
# If REDIS_URL is unset, it falls back to UPSTASH_URL (Vercel's Upstash
# integration names its generated variable that way in some setups) --
# an explicit REDIS_URL always takes precedence.

# Must be at least 32 characters. Generate with: openssl rand -hex 32
SESSION_SECRET=

RNG_VERSION=1.1

# JSON map of jurisdiction -> enabled game list, e.g. {"us":["mines"],"eu":["all"]}
JURISDICTION_FLAGS={}

# Optional. Comma-separated CORS allowlist, e.g.
# https://app.example.com,https://staging.example.com
# REQUIRED when NODE_ENV=production (the server refuses to start without it);
# leave unset in development to reflect any origin.
# CORS_ORIGIN=

# Optional platform-wide bet-amount limits. Unset = no limit (only balance
# sufficiency and positivity are enforced). Both are plain positive numbers.
# MIN_BET_AMOUNT=
# MAX_BET_AMOUNT=

# ---------------------------------------------------------------------------
# The values above target running the apps directly on the host against the
# Postgres/Redis containers (ports published to localhost). To instead run the
# ENTIRE stack in containers, you do not need a .env file at all:
#   docker compose up --build
# brings up db + redis + api + web with their own inline configuration.
